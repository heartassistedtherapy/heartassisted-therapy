<!doctype html>
<html lang="nl">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>H.A.T. (Psychotherapie) – Workshop</title>
    <link href="css/style.css" rel="stylesheet" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script>
        if (window.netlifyIdentity) {
            window.netlifyIdentity.on("init", user => {
                if (!user) {
                    window.netlifyIdentity.on("login", () => {
                        document.location.href = "/admin/";
                    });
                }
            });
        }
    </script>
</head>

<body>
    <div class="nav-bar">
        <div class="nav-inner">
            <a class="nav-title" href="#">H.A.T. (Psychotherapie) <span>Workshop</span></a>
            <ul class="nav-links">
                <li><a href="#wat-is-hat">Startpagina</a></li>
                <li><a href="#oorsprong">Over ons</a></li>
                <li><a href="#praktisch">Praktisch</a></li>
                <li><a href="#inschrijving">Inschrijving</a></li>
            </ul>
        </div>
    </div>

    <div class="page">
        <h1>{{ content.title }}</h1>
        <hr />
        <h3 style="color:blue;">Je bent hartelijk uitgenodigd voor de opleiding in de H.A.T. (Heart Assisted Therapy).
        </h3>

        {{ content.what_is_hat | markdown | safe }}

        <hr />

        <img src="https://b6b97daf17.cbaul-cdnwnd.com/bc522009c017742993e2f5b223e6381e/200000007-8bdfa8bdfe/HAT.jpg?ph=b6b97daf17"
            alt="HAT afbeelding" />


        <hr />

        <!-- 10 REDENEN -->
        <h1>{{ content.redenen_titel }}</h1>
        <ul class="reasons-grid">
            {% for reden in content.redenen %}
            <li class="reasons-card">{{ reden }}</li>
            {% endfor %}
        </ul>

        <img src="https://duyn491kcolsw.cloudfront.net/files/3e/3ev/3evmyq.jpg?ph=b6b97daf17"
            alt="Workshop afbeelding" />

        <hr />
        <!-- OORSPRONG -->
        <h1 id="oorsprong">{{ content.origin_title }}</h1>
        {{ content.origin_text | markdown | safe }}
        <p>
            <strong>De fundamenten van de Heart Assisted Therapy : de
                Hart-Brein-Connectie.</strong>
        </p>

        <!-- DOELSTELLINGEN -->
        <p>
            <strong>Doelstellingen van de workshop: Wat leert de deelnemer ?</strong>
        </p>

        <ul>
            {% for doel in content.doelstellingen %}
            <li>{{ doel }}</li>
            {% endfor %}
        </ul>

        <hr />

        <!-- PRAKTISCH -->
        <h2 id="praktisch"><strong>Basic Workshop H.A.T. - Praktisch</strong></h2>

        {% for praktisch in content.praktisch %}
        <h3><strong>{{ praktisch.titel }}</strong></h3>
        {{ praktisch.uitleg | markdown | safe}}
        {% endfor %}
        <hr />

        <h2>Inschrijving en betaling</h2>
        {{ content.betaling_en_inschrijving | markdown | safe }}
        <h3 id="inschrijving">Inschrijving</h3>
        <p>Om in te schrijven kunt uw een van de onderstaande opties kiezen en daarna <a href="#betaling">betalen</a>
        </p>
        <div style="display:flex">
            <a href="https://docs.google.com/forms/d/e/1FAIpQLSfVvSY0V8Az6HnSBMdLGMrNsVSCLSDo8aG3oSL9z1IBIYk1gg/viewform?usp=publish-editor"
                target="_blank" class="form-btn">Google Form</a>
            <a href="mailto:walter.dejongh@skynet.be?subject=Inschrijving%20HAT%20Basic%20Workshop%202026&body=Geachte%20heer%20De%20Jongh%2C%0A%0AHierbij%20schrijf%20ik%20mij%20in%20voor%20de%20HAT%20Basic%20Workshop%202026.%0A%0A%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%0APERSOONLIJKE%20GEGEVENS%0A%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%0A%0AVoornaam%3A%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20..............................%0AFamilienaam%3A%20%20%20%20%20%20%20%20%20%20%20%20%20..............................%0AWoonadres%3A%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20..............................%0AWerkadres%20(ind.%20verschillend)%3A%20..............................%0ATelefoon%20%2F%20gsm%3A%20%20%20%20%20%20%20%20%20..............................%0AE-mailadres%3A%20%20%20%20%20%20%20%20%20%20%20%20%20..............................%0AWebsite%3A%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20..............................%0A%0A%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%0APROFESSIONELE%20GEGEVENS%0A%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%0A%0ADiploma('s)%3A%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20..............................%0APsychotherapeutische%20opleiding(en)%3A%20%20%20..............................%0APsychotherapeutische%20ervaring%20(hoe%20lang)%3A%20..............................%0AAansluiting%20bij%20beroepsvereniging(en)%3A%20%20..............................%0A%0A%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%E2%80%95%0A%0AMet%20vriendelijke%20groeten%2C%0A%0A.............................."
                target="_blank" class="mail-btn">Stuur mail
            </a>

        </div>
        <h3 id="betaling">Betaling</h3>
        <p>Kies een van de onderstaande opties om te betalen:</p>
        <p style="color:var(--color-text-muted)">Vul eerst het <a href="#inschrijving">inschrijvingsformulier</a> in.
        </p>

        <div style="display:flex">
            <div class="pay-option">
                <h4>Overschrijven</h4>
                <p>Schrijf het te betalen bedrag over met deze informatie:</p>
                <div class="iban-block">
                    <strong>IBAN:</strong>
                    <br>
                    {{ content.rekeningnummer }}<br>
                    <strong>BIC/Swift:</strong><br>
                    KREDBEBB<br>
                    <strong>Naam bestemmeling:</strong><br>
                    Instituut voor Eclectische Psychologie<br>
                    <strong>Vermelding:</strong><br>
                    <em>{{ content.vermelding }}</em><br>
                    <strong>Bedrag</strong><br>
                    {{ 520 if content.is_late == false else 550 }}
                </div>
            </div>
            <div class="pay-option">
                <h4>QR-code</h4>
                <p>Scan de Qr-code en verander de vermelding zodat die dit formaat heeft:<br>
                    <em>{{ content.vermelding }}</em><br>
                    met uw volledige naam ingevuld.
                </p>
                {% if content.is_late == false %}
                <a href="https://epc-qr.eu/?bname=Instituut%20voor%20Eclectische%20Psychologie&iban=BE68733054068234&euro=520&info=HAT%20Basic%20Workshop%202026&bic=KREDBEBB"
                    target="_blank" class="qr-link">
                    <img src="./qr-code-520.png" alt="QR code betaling — klik om te betalen" style="
            width: 180px;
            height: 180px;
            margin: 8px 0;
            border: 1px solid #ddd;
            padding: 6px;
            background: #fff;
          " />
                </a>
                {% else %}
                <a href="https://epc-qr.eu/?bname=Instituut%20voor%20Eclectische%20Psychologie&iban=BE68733054068234&euro=550&info=HAT%20Basic%20Workshop%202026&bic=KREDBEBB"
                    target="_blank" class="qr-link">
                    <img src="./qr-code-550.png" alt="QR code betaling — klik om te betalen" style="
            width: 180px;
            height: 180px;
            margin: 8px 0;
            border: 1px solid #ddd;
            padding: 6px;
            background: #fff;
          " />
                </a>
                {% endif %}
                <em>Als je naam niet in de vermelding staat is het geen geldige inschrijving!</em>

            </div>
            <!-- hide for now -->
            <div class="pay-option" style="display:none">
                <h4>Online betalen</h4>
                <p>
                    Betaal online door te klikken op deze link:<br>
                    <a href="https://buy.stripe.com/test_7sY5kv5dw4985EC1FgfIs00">
                        Betaal online
                    </a>
                </p>
            </div>
        </div>

        <h3 id="annulatie">Annulatie</h3>
        {{ content.annulatie | markdown | safe }}
        <table class="ann-table">
            <thead>
                <tr>
                    <th>Tijdstip van annulatie</th>
                    <th>Terugbetaling</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Tot 1 maand vooraf</td>
                    <td>100% terugbetaald</td>
                </tr>
                <tr>
                    <td>Tot 14 dagen vóór de workshop</td>
                    <td>50% terugbetaald</td>
                </tr>
                <tr>
                    <td>Minder dan 14 dagen vooraf</td>
                    <td>Geen terugbetaling mogelijk</td>
                </tr>
            </tbody>
        </table>


    </div>

    <footer>
        <p>
            © Heart Assisted Therapy &nbsp;·&nbsp; Walter De Jongh &nbsp;·&nbsp;
            <a href="mailto:walter.dejongh@skynet.be">walter.dejongh@skynet.be</a>
        </p>
    </footer>
</body>

</html>
